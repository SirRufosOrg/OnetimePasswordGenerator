<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="otpApp.App"
             xmlns:zafiro="using:Zafiro.Avalonia.ViewLocators"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <zafiro:DataTypeViewLocator />
        <DataTemplateInclude Source="avares://Zafiro.Avalonia/DataTemplates.axaml" />
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://otpApp/Themes/Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://otpApp/Themes/Styles.axaml" />
    </Application.Styles>
</Application>
