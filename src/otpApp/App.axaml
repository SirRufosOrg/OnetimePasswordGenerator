<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:otpApp.Converters"
             x:Class="otpApp.App"
             x:DataType="vm:MainWindowViewModel"
             xmlns:vm="using:otpApp.ViewModels"
             xmlns:zafiro="using:Zafiro.Avalonia.ViewLocators"
             Name="otpApp"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://otpApp/Themes/Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:InvertBoolConverter x:Key="InvertBool"/>
            <local:StringNotEmptyConverter x:Key="NotEmpty"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <zafiro:DataTypeViewLocator />
        <DataTemplateInclude Source="avares://Zafiro.Avalonia/DataTemplates.axaml" />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://otpApp/Themes/Styles.axaml" />
    </Application.Styles>

    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="{Binding Loc.AppCmdAbout}" Command="{Binding ShowAboutCommand}" />
        </NativeMenu>
    </NativeMenu.Menu>

</Application>
