<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:otpApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="700"
        x:Class="otpApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Loc.AppTitle}"
        Background="{DynamicResource SurfaceDefaultBrush}"
        CanMaximize="False"
        MinWidth="520"
        MaxWidth="520"
        Width="520"
        Height="780"
        WindowStartupLocation="CenterScreen">

    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="{Binding Loc.MenuFile}">
                <NativeMenu>
                    <NativeMenuItem Header="{Binding Loc.MenuNewAccount}" Command="{Binding ShowAddCommand}"/>
                    <NativeMenuItem Header="{Binding Loc.ImportFromClipboard}" Command="{Binding ImportFromClipboardCommand}"/>
                    <NativeMenuItemSeparator/>
                    <NativeMenuItem Header="{Binding Loc.MenuImportFile}" Command="{Binding ImportFromFileCommand}"/>
                    <NativeMenuItem Header="{Binding Loc.MenuExportFile}" Command="{Binding ExportToFileCommand}"/>
                </NativeMenu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Border Background="{DynamicResource SurfaceCardBrush}" Padding="20,16">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" VerticalAlignment="Center" ColumnSpacing="8">
                <StackPanel>
                    <TextBlock Text="{Binding Loc.AppTitle}" Classes="HeaderText"/>
                    <TextBlock Text="{Binding Loc.AppSubtitle}" Classes="SubHeaderText"/>
                </StackPanel>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Languages}"
                          SelectedIndex="{Binding SelectedCultureIndex}"
                          VerticalAlignment="Center"
                          Width="110"
                          Background="{DynamicResource SurfaceSubtleBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          CornerRadius="8"
                          BorderThickness="0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="4,2"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Command="{Binding ShowAboutCommand}"
                        IsVisible="{Binding ShowAboutButton}"
                        Classes="IconButton"
                        ToolTip.Tip="{Binding Loc.AboutTooltip}"
                        VerticalAlignment="Center">
                    <TextBlock Text="?" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <SplitButton Grid.Column="3" Command="{Binding ShowAddCommand}"
                             Classes="PrimaryButton"
                             VerticalAlignment="Center">
                    <TextBlock Text="{Binding Loc.AddAccountButton}"/>
                    <SplitButton.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{Binding Loc.ImportFromClipboard}"
                                      Command="{Binding ImportFromClipboardCommand}"/>
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>
            </Grid>
        </Border>

        <!-- Status Message -->
        <Border Grid.Row="1" IsVisible="{Binding StatusMessage, Converter={StaticResource NotEmpty}}"
                Background="#80D32F2F"
                Padding="16,8"
                Margin="16,8,16,0"
                CornerRadius="8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontSize="13"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" Margin="16,12,16,0" x:Name="ContentScrollViewer">
            <StackPanel Spacing="0">
                <!-- Account Cards List -->
                <ItemsControl ItemsSource="{Binding Accounts}"
                              Background="Transparent"
                              BorderThickness="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AccountItemViewModel">
                            <Border Classes="Card">
                                <Grid>
                                    <!-- Display Mode -->
                                    <StackPanel IsVisible="{Binding IsEditing, Converter={StaticResource InvertBool}}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayIssuer}" Classes="IssuerLabel"/>
                                                <TextBlock Text="{Binding DisplayLabel}" Classes="LabelText"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                        VerticalAlignment="Top">
                                                <Button Command="{Binding CopyCommand}"
                                                        Classes="IconButton"
                                                        ToolTip.Tip="{Binding Loc.CopyTooltip}">
                                                    <TextBlock Text="◆" FontSize="16"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Button>
                                                <Button Command="{Binding EditCommand}"
                                                        Classes="IconButton"
                                                        ToolTip.Tip="{Binding Loc.EditTooltip}">
                                                    <TextBlock Text="✎" FontSize="16"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Button>
                                                <Button Command="{Binding DeleteCommand}"
                                                        Classes="IconButton"
                                                        ToolTip.Tip="{Binding Loc.DeleteTooltip}">
                                                    <TextBlock Text="✕" FontSize="16"
                                                               Foreground="{DynamicResource AccentRedBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- TOTP -->
                                        <StackPanel IsVisible="{Binding IsTotp}" Margin="0,8,0,0">
                                            <ItemsControl ItemsSource="{Binding CurrentCode, Converter={StaticResource CodeSplitter}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="10"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="x:String">
                                                        <TextBlock Text="{Binding}" Classes="Code"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="1" Classes="CountdownBar"/>
                                            <TextBlock Text="{Binding RemainingSeconds, StringFormat='{}s'}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- HOTP -->
                                        <StackPanel IsVisible="{Binding IsTotp, Converter={StaticResource InvertBool}}" Margin="0,8,0,0">
                                            <ItemsControl ItemsSource="{Binding CurrentCode, Converter={StaticResource CodeSplitter}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="10"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="x:String">
                                                        <TextBlock Text="{Binding}" Classes="Code"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Loc.Counter}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding Counter}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Command="{Binding NextCodeCommand}"
                                                        Content="{Binding Loc.NextCode}"
                                                        FontSize="11"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Edit Mode -->
                                    <StackPanel IsVisible="{Binding IsEditing}" Spacing="8">
                                        <TextBox Text="{Binding EditIssuer}"
                                                 PlaceholderText="{Binding Loc.IssuerPlaceholder}"
                                                 ToolTip.Tip="{Binding Loc.IssuerTooltip}"
                                                 Classes="UrlTextBox"/>
                                        <TextBox Text="{Binding EditLabel}"
                                                 PlaceholderText="{Binding Loc.LabelPlaceholder}"
                                                 ToolTip.Tip="{Binding Loc.LabelTooltip}"
                                                 Classes="UrlTextBox"/>
                                        <TextBox Text="{Binding EditSecret}"
                                                 PlaceholderText="{Binding Loc.SecretPlaceholder}"
                                                 ToolTip.Tip="{Binding Loc.SecretTooltip}"
                                                 Classes="UrlTextBox"/>

                                        <ComboBox ItemsSource="{Binding Algorithms}"
                                                  SelectedItem="{Binding EditAlgorithm}"
                                                  ToolTip.Tip="{Binding Loc.AlgorithmTooltip}"
                                                  Classes="UrlTextBox"
                                                  HorizontalAlignment="Stretch"/>

                                        <ComboBox ItemsSource="{Binding OtpTypes}"
                                                  SelectedItem="{Binding EditType}"
                                                  ToolTip.Tip="{Binding Loc.TypeTooltip}"
                                                  Classes="UrlTextBox"
                                                  HorizontalAlignment="Stretch"/>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <NumericUpDown Value="{Binding EditDigits}"
                                                           Minimum="6" Maximum="8" Increment="2"
                                                           FormatString="0"
                                                           ToolTip.Tip="{Binding Loc.DigitsTooltip}"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.DigitsPlaceholder}"/>
                                            <NumericUpDown Grid.Column="1"
                                                           Value="{Binding EditPeriod}"
                                                           IsVisible="{Binding IsEditTotp}"
                                                           Minimum="1" Maximum="3600" Increment="1"
                                                           FormatString="0"
                                                           ToolTip.Tip="{Binding Loc.PeriodTooltip}"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.PeriodPlaceholder}"/>
                                            <NumericUpDown Grid.Column="1"
                                                           Value="{Binding EditCounter}"
                                                           IsVisible="{Binding IsEditTotp, Converter={StaticResource InvertBool}}"
                                                           Minimum="0" Maximum="999999" Increment="1"
                                                           FormatString="0"
                                                           ToolTip.Tip="{Binding Loc.CounterTooltip}"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.CounterPlaceholder}"/>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                            <Button Command="{Binding CancelEditCommand}"
                                                    Background="{DynamicResource SurfaceSubtleBrush}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    CornerRadius="8"
                                                    Padding="16,8"
                                                    Content="{Binding Loc.Cancel}"/>
                                            <Button Command="{Binding SaveEditCommand}"
                                                    Classes="PrimaryButton"
                                                    Content="{Binding Loc.Save}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ContentControl Content="{Binding AddAccountViewModel}"
                                IsVisible="{Binding ShowAddDialog}"
                                Margin="0,12,0,0">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:AddAccountViewModel">
                            <Border Background="#80000000" CornerRadius="12" Padding="20">
                                <Border Background="{DynamicResource SurfaceCardBrush}"
                                        CornerRadius="12" Padding="24">
                                    <StackPanel Spacing="16">
                                        <TextBlock Text="{Binding Loc.AddAccountDialogTitle}" Classes="HeaderText"/>
                                        <TextBlock Text="{Binding Loc.AddAccountDialogSubtitle}" Classes="SubHeaderText"/>

                                        <TextBox PlaceholderText="{Binding Loc.IssuerPlaceholder}"
                                                 Text="{Binding Issuer}"
                                                 ToolTip.Tip="{Binding Loc.IssuerTooltip}"
                                                 Classes="UrlTextBox"/>
                                        <TextBox PlaceholderText="{Binding Loc.LabelPlaceholder}"
                                                 Text="{Binding Label}"
                                                 ToolTip.Tip="{Binding Loc.LabelTooltip}"
                                                 Classes="UrlTextBox"/>
                                        <TextBox PlaceholderText="{Binding Loc.SecretPlaceholder}"
                                                 Text="{Binding Secret}"
                                                 ToolTip.Tip="{Binding Loc.SecretTooltip}"
                                                 Classes="UrlTextBox"/>

                                        <ComboBox ItemsSource="{Binding Algorithms}"
                                                  SelectedItem="{Binding Algorithm}"
                                                  ToolTip.Tip="{Binding Loc.AlgorithmTooltip}"
                                                  Classes="UrlTextBox" HorizontalAlignment="Stretch"/>

                                        <ComboBox ItemsSource="{Binding OtpTypes}"
                                                  SelectedItem="{Binding Type}"
                                                  ToolTip.Tip="{Binding Loc.TypeTooltip}"
                                                  Classes="UrlTextBox" HorizontalAlignment="Stretch"/>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <NumericUpDown Value="{Binding Digits}"
                                                           Minimum="6" Maximum="8" Increment="2"
                                                           FormatString="0"
                                                           ToolTip.Tip="{Binding Loc.DigitsTooltip}"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.DigitsPlaceholder}"/>
                                            <NumericUpDown Grid.Column="1"
                                                           Value="{Binding Period}"
                                                           IsVisible="{Binding IsTotp}"
                                                           Minimum="1" Maximum="3600" Increment="1"
                                                           FormatString="0"
                                                           ToolTip.Tip="{Binding Loc.PeriodTooltip}"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.PeriodPlaceholder}"/>
                                            <NumericUpDown Grid.Column="1"
                                                           Value="{Binding HotpCounter}"
                                                           IsVisible="{Binding IsTotp, Converter={StaticResource InvertBool}}"
                                                           Minimum="0" Maximum="999999" Increment="1"
                                                           FormatString="0"
                                                           ToolTip.Tip="{Binding Loc.CounterTooltip}"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.CounterPlaceholder}"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Button Command="{Binding CancelCommand}"
                                                    Background="{DynamicResource SurfaceSubtleBrush}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    CornerRadius="8" Padding="16,8"
                                                    Content="{Binding Loc.Cancel}"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding SaveCommand}"
                                                    Classes="PrimaryButton"
                                                    Content="{Binding Loc.Save}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
