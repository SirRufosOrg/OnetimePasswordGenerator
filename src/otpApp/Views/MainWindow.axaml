<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:otpApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="700"
        x:Class="otpApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Loc.AppTitle}"
        Background="{DynamicResource SurfaceDefaultBrush}"
        Width="520"
        Height="780"
        WindowStartupLocation="CenterScreen">

    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="{Binding Loc.CmdAbout}" Command="{Binding ShowAboutCommand}"/>
            <NativeMenuItemSeparator/>
        </NativeMenu>
    </NativeMenu.Menu>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Background="{DynamicResource SurfaceCardBrush}" Padding="20,16">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" VerticalAlignment="Center" ColumnSpacing="8">
                <StackPanel>
                    <TextBlock Text="{Binding Loc.AppTitle}" Classes="HeaderText"/>
                    <TextBlock Text="{Binding Loc.AppSubtitle}" Classes="SubHeaderText"/>
                </StackPanel>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Languages}"
                          SelectedIndex="{Binding SelectedCultureIndex}"
                          VerticalAlignment="Center"
                          Width="110"
                          Background="{DynamicResource SurfaceSubtleBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          CornerRadius="8"
                          BorderThickness="0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="4,2"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Command="{Binding ShowAboutCommand}"
                        IsVisible="{Binding ShowAboutButton}"
                        Classes="IconButton"
                        ToolTip.Tip="{Binding Loc.AboutTooltip}"
                        VerticalAlignment="Center">
                    <TextBlock Text="?" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
                <Button Grid.Column="3" Command="{Binding ShowAddCommand}"
                        Classes="PrimaryButton" Content="{Binding Loc.AddAccountButton}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="16,12,16,0">
            <StackPanel Spacing="0">
                <!-- Account Cards List -->
                <ItemsControl ItemsSource="{Binding Accounts}"
                              Background="Transparent"
                              BorderThickness="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AccountItemViewModel">
                            <Border Classes="Card">
                                <Grid>
                                    <!-- Display Mode -->
                                    <StackPanel IsVisible="{Binding IsEditing, Converter={StaticResource InvertBool}}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Account.Issuer}" Classes="IssuerLabel"/>
                                                <TextBlock Text="{Binding Account.Label}" Classes="LabelText"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                        VerticalAlignment="Top">
                                                <Button Command="{Binding CopyCommand}"
                                                        Classes="IconButton"
                                                        ToolTip.Tip="{Binding Loc.CopyTooltip}">
                                                    <TextBlock Text="◆" FontSize="16"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Button>
                                                <Button Command="{Binding EditCommand}"
                                                        Classes="IconButton"
                                                        ToolTip.Tip="{Binding Loc.EditTooltip}">
                                                    <TextBlock Text="✎" FontSize="16"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Button>
                                                <Button Command="{Binding DeleteCommand}"
                                                        Classes="IconButton"
                                                        ToolTip.Tip="{Binding Loc.DeleteTooltip}">
                                                    <TextBlock Text="✕" FontSize="16"
                                                               Foreground="{DynamicResource AccentRedBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="{Binding CurrentCode}" Classes="Code"/>
                                            <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="1" Classes="CountdownBar"/>
                                            <TextBlock Text="{Binding RemainingSeconds, StringFormat='{}s'}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Edit Mode -->
                                    <StackPanel IsVisible="{Binding IsEditing}" Spacing="8">
                                        <TextBox Text="{Binding EditIssuer}"
                                                 PlaceholderText="{Binding Loc.IssuerPlaceholder}"
                                                 Classes="UrlTextBox"/>
                                        <TextBox Text="{Binding EditLabel}"
                                                 PlaceholderText="{Binding Loc.LabelPlaceholder}"
                                                 Classes="UrlTextBox"/>
                                        <TextBox Text="{Binding EditSecret}"
                                                 PlaceholderText="{Binding Loc.SecretPlaceholder}"
                                                 Classes="UrlTextBox"/>

                                        <ComboBox ItemsSource="{Binding Algorithms}"
                                                  SelectedItem="{Binding EditAlgorithm}"
                                                  Classes="UrlTextBox"
                                                  HorizontalAlignment="Stretch"/>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <NumericUpDown Value="{Binding EditDigits}"
                                                           Minimum="1" Maximum="10" Increment="1"
                                                           FormatString="0"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.DigitsPlaceholder}"/>
                                            <NumericUpDown Grid.Column="1"
                                                           Value="{Binding EditPeriod}"
                                                           Minimum="1" Maximum="3600" Increment="1"
                                                           FormatString="0"
                                                           Classes="UrlTextBox"
                                                           PlaceholderText="{Binding Loc.PeriodPlaceholder}"/>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                            <Button Command="{Binding CancelEditCommand}"
                                                    Background="{DynamicResource SurfaceSubtleBrush}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    CornerRadius="8"
                                                    Padding="16,8"
                                                    Content="{Binding Loc.Cancel}"/>
                                            <Button Command="{Binding SaveEditCommand}"
                                                    Classes="PrimaryButton"
                                                    Content="{Binding Loc.Save}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Account Dialog Overlay -->
                <Border IsVisible="{Binding ShowAddDialog}"
                        Background="#80000000"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,12,0,0">
                    <Border Background="{DynamicResource SurfaceCardBrush}"
                            CornerRadius="12"
                            Padding="24">
                        <StackPanel Spacing="16">
                            <TextBlock Text="{Binding Loc.AddAccountDialogTitle}" Classes="HeaderText"/>
                            <TextBlock Text="{Binding Loc.AddAccountDialogSubtitle}"
                                       Classes="SubHeaderText"/>

                            <TextBox PlaceholderText="{Binding Loc.IssuerPlaceholder}"
                                     Text="{Binding AddAccountViewModel.Issuer}"
                                     Classes="UrlTextBox"/>
                            <TextBox PlaceholderText="{Binding Loc.LabelPlaceholder}"
                                     Text="{Binding AddAccountViewModel.Label}"
                                     Classes="UrlTextBox"/>
                            <TextBox PlaceholderText="{Binding Loc.SecretPlaceholder}"
                                     Text="{Binding AddAccountViewModel.Secret}"
                                     Classes="UrlTextBox"/>

                            <ComboBox ItemsSource="{Binding AddAccountViewModel.Algorithms}"
                                      SelectedItem="{Binding AddAccountViewModel.Algorithm}"
                                      Classes="UrlTextBox"
                                      HorizontalAlignment="Stretch"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <NumericUpDown Value="{Binding AddAccountViewModel.Digits}"
                                               Minimum="1" Maximum="10" Increment="1"
                                               FormatString="0"
                                               Classes="UrlTextBox"
                                               PlaceholderText="{Binding Loc.DigitsPlaceholder}"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding AddAccountViewModel.Period}"
                                               Minimum="1" Maximum="3600" Increment="1"
                                               FormatString="0"
                                               Classes="UrlTextBox"
                                               PlaceholderText="{Binding Loc.PeriodPlaceholder}"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Button Command="{Binding AddAccountViewModel.CancelCommand}"
                                        Background="{DynamicResource SurfaceSubtleBrush}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        CornerRadius="8"
                                        Padding="16,8"
                                        Content="{Binding Loc.Cancel}"/>
                                <Button Grid.Column="1"
                                        Command="{Binding AddAccountViewModel.SaveCommand}"
                                        Classes="PrimaryButton"
                                        Content="{Binding Loc.Save}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
