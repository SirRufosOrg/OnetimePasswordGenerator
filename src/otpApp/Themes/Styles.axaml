<Styles xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Border.Card">
        <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style Selector="TextBlock.Code">
        <Setter Property="FontFamily" Value="ui-monospace, Consolas, Courier New, monospace"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextCodeBrush}"/>
        <Setter Property="LetterSpacing" Value="4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.IssuerLabel">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.LabelText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.CountdownText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.IconButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.IconButton:hover">
        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}"/>
    </Style>

    <Style Selector="ProgressBar.CountdownBar">
        <Setter Property="Height" Value="4"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
    </Style>

    <Style Selector="ProgressBar.CountdownBar.ExpiringSoon">
        <Setter Property="Foreground" Value="{DynamicResource AccentYellowBrush}"/>
    </Style>

    <Style Selector="ProgressBar.CountdownBar.Expiring">
        <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}"/>
    </Style>

    <Style Selector="TextBox.UrlTextBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="TextBox.UrlTextBox:focus-within">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.HeaderText">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.SubHeaderText">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>
</Styles>
